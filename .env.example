# ────────────────────────────────────────────────────────────────────────────
# Hotel Siddhi Vinayak — environment variables
# Copy this file to `.env.local` for local dev, and add the same keys in
# Vercel → Project → Settings → Environment Variables for production.
# NEVER commit real secrets. `.env*` is gitignored.
# ────────────────────────────────────────────────────────────────────────────

# 🔑 AiSensy API Campaign Key (AiSensy Dashboard → Manage → API Key).
#    This is the long token. It is used ONLY on the server.
AISENSY_API_KEY=

# AiSensy Campaign API endpoint (override only if AiSensy changes it).
AISENSY_API_URL=https://backend.aisensy.com/campaign/t1/api/v2

# Hotel WhatsApp number that receives lead notifications (country code, no +).
ADMIN_WHATSAPP_NUMBER=918952802559

# Approved AiSensy template / campaign names (create these in AiSensy first).
AISENSY_TPL_GUEST_THANKYOU=guest_thank_you
AISENSY_TPL_BOOKING=booking_confirmation
AISENSY_TPL_ADMIN_LEAD=admin_lead_notification

# Shared secret for the inbound WhatsApp webhook (any long random string).
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Optional — durable lead storage via Vercel KV (Storage → KV → .env.local tab).
# If unset, leads are still captured in Vercel logs.
KV_REST_API_URL=
KV_REST_API_TOKEN=
